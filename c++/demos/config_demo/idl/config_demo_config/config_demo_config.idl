#import "rpc/rpc_types.idl"
#import "connection_factory_config/connection_factory_config.idl"

namespace config_demo
{
    namespace v1
    {
        struct demo_settings
        {
            [description="Number of calculator RPC rounds to run."]
            uint64_t iterations = 1;

            [description="Thread count for each demo scheduler."]
            uint32_t scheduler_threads = 4;

            [description="Named connector connection used by the demo client."]
            std::string client_connection = "client";

            [description="Named acceptor connection used by paired stream RPC demos. Leave empty for native connector-only transports."]
            std::string server_connection = "server";

            [description="Host-side RPC resources that the connection factory can place into connection contexts. TLS material belongs to each tls stream layer."]
            rpc::connection_factory::rpc_runtime_settings rpc_runtime = {};

            [description="Named connector and acceptor definitions that the application looks up and passes to the connection factory."]
            std::vector<rpc::connection_factory::named_connection_settings> connections = {};
        };
    }
}

{
  "$schema": "../schemas/config_demo_config.schema.json",
  "execution": {
    "iterations": 1,
    "client_connection": "client",
    "server_connection": ""
  },
  "connections": [
    {
      "name": "client",
      "role": "connector",
      "zone_subnet": 301,
      "connection": {
        "service": {
          "type": "service",
          "settings": {
            "name": "config_demo_sgx_blocking_host",
            "executor": {
              "thread_count": 2
            }
          }
        },
        "transport": {
          "type": "sgx_blocking",
          "settings": {
            "name": "config_demo_sgx_blocking_transport",
            "service_proxy_name": "config_demo_sgx_calculator",
            "encoding": "yas_binary",
            "enclave_path": "/path/to/libconfig_demo_calculator_blocking_enclave.signed.so",
            "enclave": {}
          }
        }
      }
    }
  ]
}

{
  "$schema": "../schemas/config_demo_config.schema.json",
  "execution": {
    "iterations": 1,
    "client_connection": "client",
    "server_connection": ""
  },
  "connections": [
    {
      "name": "client",
      "role": "connector",
      "zone_subnet": 305,
      "connection": {
        "service": {
          "type": "service",
          "settings": {
            "name": "config_demo_unshared_scheduler_dll_host",
            "executor": {
              "thread_count": 2
            }
          }
        },
        "transport": {
          "type": "unshared_scheduler_dll",
          "settings": {
            "name": "config_demo_unshared_scheduler_dll_transport",
            "service_proxy_name": "config_demo_unshared_scheduler_dll_calculator",
            "encoding": "yas_binary",
            "dynamic_library_path": "/path/to/libconfig_demo_calculator_unshared_scheduler_payload.so"
          }
        }
      }
    }
  ]
}

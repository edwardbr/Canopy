{
  "$schema": "../schemas/config_demo_config.schema.json",
  "execution": {
    "iterations": 1,
    "client_connection": "client",
    "server_connection": "server"
  },
  "attestation_services": [
    {
      "name": "server_attestation",
      "backend": "fake_backend",
      "identity": {
        "enclave_id": "config-demo-server",
        "zone_id": "server-zone"
      },
      "policy": {
        "send_local_evidence": true,
        "require_peer_evidence": true,
        "allow_unattested_peer": false,
        "allow_development_evidence": true,
        "minimum_security_level": "development",
        "required_backend_id": "fake"
      }
    },
    {
      "name": "client_attestation",
      "backend": "fake_backend",
      "identity": {
        "enclave_id": "config-demo-client",
        "zone_id": "client-zone"
      },
      "policy": {
        "send_local_evidence": true,
        "require_peer_evidence": true,
        "allow_unattested_peer": false,
        "allow_development_evidence": true,
        "minimum_security_level": "development",
        "required_backend_id": "fake"
      }
    }
  ],
  "connections": [
    {
      "name": "server",
      "role": "acceptor",
      "zone_subnet": 3,
      "connection": {
        "service": {
          "type": "service",
          "settings": {
            "name": "config_demo_secure_server",
            "executor": {
              "thread_count": 4
            }
          }
        },
        "listener": {
          "type": "stream_rpc",
          "settings": {
            "name": "config_demo_secure_listener"
          }
        },
        "transport": {
          "type": "stream_rpc",
          "settings": {
            "name": "config_demo_secure_server_transport",
            "service_proxy_name": "config_demo_secure_client",
            "encoding": "yas_binary",
            "call_timeout": 30000,
            "call_timeout_sweep": 1,
            "shutdown_timeout": 5000
          }
        },
        "stream_layers": [
          {
            "type": "tcp_coroutine",
            "settings": {
              "host": "127.0.0.1",
              "port": 26071,
              "ipv6": false,
              "connect_timeout": 5000
            }
          },
          {
            "type": "tls",
            "settings": {
              "client": {
                "verify_peer": false,
                "trust_anchor": ""
              },
              "server": {
                "verify_peer": "none",
                "credentials": {
                  "certificate_file": "../certs/server.crt",
                  "private_key_file": "../certs/server.key"
                }
              }
            }
          },
          {
            "type": "websocket",
            "settings": {
              "keep_alive": {
                "enabled": false
              },
              "max_message_bytes": 1048576,
              "max_frame_payload_bytes": 1048576,
              "max_decoded_messages": 16
            }
          },
          {
            "type": "attestation",
            "settings": {
              "transcript_id": 1,
              "handshake_timeout_ms": 5000,
              "service_name": "server_attestation"
            }
          }
        ]
      }
    },
    {
      "name": "client",
      "role": "connector",
      "zone_subnet": 102,
      "connection": {
        "service": {
          "type": "service",
          "settings": {
            "name": "config_demo_secure_client",
            "executor": {
              "thread_count": 4
            }
          }
        },
        "transport": {
          "type": "stream_rpc",
          "settings": {
            "name": "config_demo_secure_client_transport",
            "service_proxy_name": "config_demo_secure_server",
            "encoding": "yas_binary",
            "call_timeout": 30000,
            "call_timeout_sweep": 1,
            "shutdown_timeout": 5000
          }
        },
        "stream_layers": [
          {
            "type": "tcp_coroutine",
            "settings": {
              "host": "127.0.0.1",
              "port": 26071,
              "ipv6": false,
              "connect_timeout": 5000
            }
          },
          {
            "type": "tls",
            "settings": {
              "client": {
                "verify_peer": false,
                "trust_anchor": ""
              },
              "server": {
                "verify_peer": "none",
                "credentials": {
                  "certificate_file": "../certs/server.crt",
                  "private_key_file": "../certs/server.key"
                }
              }
            }
          },
          {
            "type": "websocket",
            "settings": {
              "keep_alive": {
                "enabled": false
              },
              "max_message_bytes": 1048576,
              "max_frame_payload_bytes": 1048576,
              "max_decoded_messages": 16
            }
          },
          {
            "type": "attestation",
            "settings": {
              "transcript_id": 1,
              "handshake_timeout_ms": 5000,
              "service_name": "client_attestation"
            }
          }
        ]
      }
    }
  ]
}

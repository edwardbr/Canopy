#pragma once

#if !defined(FOR_SGX)
#  error "rpc/internal/polyfill/sgx/coroutine is only valid for SGX builds"
#endif

#if !defined(__cpp_impl_coroutine)
#  error "Compiler coroutine support is required for SGX coroutine builds"
#endif

#include <cstddef>
#include <type_traits>

namespace std
{
    template<typename result_type, typename... arg_types> struct coroutine_traits;

    template<typename result_type, typename = void> struct coroutine_traits_impl
    {
    };

    template<typename result_type>
    struct coroutine_traits_impl<result_type, std::void_t<typename result_type::promise_type>>
    {
        using promise_type = typename result_type::promise_type;
    };

    template<typename result_type, typename... arg_types> struct coroutine_traits : coroutine_traits_impl<result_type>
    {
    };

    template<typename promise_type = void> struct coroutine_handle;

    template<> struct coroutine_handle<void>
    {
        constexpr coroutine_handle() noexcept = default;
        constexpr coroutine_handle(nullptr_t) noexcept
            : frame_(nullptr)
        {
        }

        coroutine_handle& operator=(nullptr_t) noexcept
        {
            frame_ = nullptr;
            return *this;
        }

        [[nodiscard]] constexpr void* address() const noexcept { return frame_; }

        [[nodiscard]] static constexpr coroutine_handle from_address(void* address) noexcept
        {
            coroutine_handle self;
            self.frame_ = address;
            return self;
        }

        [[nodiscard]] constexpr explicit operator bool() const noexcept { return frame_ != nullptr; }

        [[nodiscard]] bool done() const noexcept { return __builtin_coro_done(frame_); }

        void operator()() const { resume(); }
        void resume() const { __builtin_coro_resume(frame_); }
        void destroy() const { __builtin_coro_destroy(frame_); }

    protected:
        void* frame_ = nullptr;
    };

    inline constexpr bool operator==(
        coroutine_handle<> lhs,
        coroutine_handle<> rhs) noexcept
    {
        return lhs.address() == rhs.address();
    }

    inline constexpr bool operator!=(
        coroutine_handle<> lhs,
        coroutine_handle<> rhs) noexcept
    {
        return !(lhs == rhs);
    }

    inline constexpr bool operator==(
        coroutine_handle<> lhs,
        nullptr_t) noexcept
    {
        return lhs.address() == nullptr;
    }

    inline constexpr bool operator!=(
        coroutine_handle<> lhs,
        nullptr_t) noexcept
    {
        return !(lhs == nullptr);
    }

    template<typename promise_type> struct coroutine_handle : coroutine_handle<>
    {
        using coroutine_handle<>::coroutine_handle;

        [[nodiscard]] static coroutine_handle from_promise(promise_type& promise) noexcept
        {
            coroutine_handle self;
            self.frame_ = __builtin_coro_promise(&promise, alignof(promise_type), true);
            return self;
        }

        [[nodiscard]] static constexpr coroutine_handle from_address(void* address) noexcept
        {
            coroutine_handle self;
            self.frame_ = address;
            return self;
        }

        [[nodiscard]] promise_type& promise() const noexcept
        {
            return *reinterpret_cast<promise_type*>(__builtin_coro_promise(this->frame_, alignof(promise_type), false));
        }
    };

    struct suspend_never
    {
        [[nodiscard]] constexpr bool await_ready() const noexcept { return true; }
        constexpr void await_suspend(coroutine_handle<>) const noexcept { }
        constexpr void await_resume() const noexcept { }
    };

    struct suspend_always
    {
        [[nodiscard]] constexpr bool await_ready() const noexcept { return false; }
        constexpr void await_suspend(coroutine_handle<>) const noexcept { }
        constexpr void await_resume() const noexcept { }
    };

    struct noop_coroutine_promise
    {
    };

    using noop_coroutine_handle = coroutine_handle<noop_coroutine_promise>;

    [[nodiscard]] inline noop_coroutine_handle noop_coroutine() noexcept
    {
        return noop_coroutine_handle::from_address(__builtin_coro_noop());
    }
}

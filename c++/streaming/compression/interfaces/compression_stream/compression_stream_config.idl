#import "rpc/rpc_types.idl"

namespace rpc
{
    namespace compression_stream
    {
        enum compression_algorithm : uint8_t
        {
            zstd = 0,
        };

        // Settings for the compression stream layer.
        //
        // Compression is a stream transform. It wraps an already-created byte
        // stream and must be ordered deliberately with security layers. For
        // browser/untrusted-web style endpoints, compression before encryption
        // can create side channels when secrets and attacker-controlled input
        // are compressed together. Use this layer only where that ordering is
        // acceptable for the application threat model.
        struct stream_settings
        {
            [description="Compression algorithm. The initial implementation supports Zstandard."]
            compression_algorithm algorithm = compression_algorithm::zstd;

            [description="Zstandard compression level. The Zstd library clamps unsupported values to its implementation-defined bounds."]
            int32_t level = 3;

            [description="Bytes in the intermediate compression output buffer. Zero selects the implementation default."]
            uint64_t send_buffer_bytes = 16384;

            [description="Bytes read from the underlying compressed stream at a time. Zero selects the implementation default."]
            uint64_t receive_buffer_bytes = 16384;

            [description="Maximum decompressed bytes allowed from one compressed input chunk, expressed as a multiplier of compressed bytes. Zero disables this guard; public endpoints should set a finite value."]
            uint64_t max_expansion_ratio = 0;
        };
    }
}

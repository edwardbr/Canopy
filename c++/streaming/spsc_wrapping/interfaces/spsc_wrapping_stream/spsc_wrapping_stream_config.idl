#import "rpc/rpc_types.idl"

namespace rpc
{
    namespace spsc_wrapping_stream
    {
        // Settings for the SPSC wrapper stream layer.
        //
        // The current implementation is intentionally configured mostly by its
        // construction context: it needs an underlying stream and a scheduler.
        // This struct still gives the layer a typed IDL-owned JSON shape so a
        // generic factory can validate a spsc_wrapping layer entry without
        // borrowing options from unrelated stream implementations.
        struct stream_settings
        {
            [description="Optional diagnostic label for the wrapper instance."]
            rpc::optional<std::string> name;
        };
    }
}

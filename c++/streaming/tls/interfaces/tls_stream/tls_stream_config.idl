#import "rpc/rpc_types.idl"

namespace rpc
{
    namespace tls_stream
    {
        enum peer_verification : uint8_t
        {
            none = 0,
            optional = 1,
            required = 2,
        };

        // PEM material used when a factory constructs an OpenSSL TLS
        // server or client context from configuration. Empty fields mean
        // the caller must supply the corresponding context object out of
        // band.
        struct pem_credentials
        {
            [description="PEM encoded leaf certificate or certificate chain."]
            std::string certificate;

            [description="PEM encoded private key matching the certificate."]
            std::string private_key;

            [description="PEM encoded trust anchor used when peer verification is enabled."]
            std::string trust_anchor;
        };

        struct server_context_settings
        {
            [description="Peer certificate verification policy used by an OpenSSL TLS server context."]
            peer_verification verify_peer = peer_verification::none;

            [description="Optional inline PEM material for factories that construct the server context from JSON."]
            rpc::optional<pem_credentials> credentials;
        };

        struct client_context_settings
        {
            [description="Require peer certificate verification when constructing an OpenSSL TLS client context."]
            bool verify_peer = false;

            [description="Optional PEM trust anchor used by the client context when verify_peer is true."]
            std::string trust_anchor;
        };

        // Stream-layer settings. The live stream object still receives a
        // concrete context object; this IDL describes the JSON shape a
        // factory can materialise before creating that context.
        struct stream_settings
        {
            [description="Client-side context settings used when connecting through an OpenSSL TLS stream layer."]
            client_context_settings client = {};

            [description="Server-side context settings used when accepting through an OpenSSL TLS stream layer."]
            server_context_settings server = {};
        };
    }
}

// Test-only RPC interface for exercising attestation code inside an enclave.
// Production attestation protocols live under interfaces/attestation.

namespace attestation_test
{
    [inline] namespace v4
    {
        struct sgx_sim_report_self_test_result
        {
            bool produced_report_evidence = false;
            bool producer_verified_report = false;
            bool verifier_accepted_report = false;
            uint64_t payload_size = 0;
            uint64_t report_size = 0;
            uint64_t target_info_size = 0;
            uint64_t report_data_hash_size = 0;
            uint64_t development_signature_size = 0;
            std::string content_format;
            std::string verifier_reason;
        };

        struct sgx_sim_local_attestation_verification
        {
            bool accepted = false;
            bool report_data_matched = false;
            bool sgx_verify_report_succeeded = false;
            uint64_t report_size = 0;
            uint64_t expected_report_data_size = 0;
            std::string failure_reason;
        };

        struct sgx_sim_test_cmw
        {
            std::string media_type;
            std::string content_format;
            std::vector<uint8_t> payload;
        };

        interface i_attestation_enclave_test
        {
            int sgx_sim_report_self_test([out] sgx_sim_report_self_test_result& details);
            // Verifier enclave creates a challenge for a peer enclave.
            int sgx_sim_make_local_attestation_challenge(
                [in] uint8_t challenge_seed,
                [out] sgx_sim_test_cmw& challenge);
            // Prover enclave consumes the verifier challenge and creates a
            // report targeted at that verifier enclave.
            int sgx_sim_make_local_attestation_report(
                [in] const sgx_sim_test_cmw& challenge,
                [out] sgx_sim_test_cmw& report);
            // Verifier enclave checks both SGX report authenticity and the
            // application-level report_data transcript binding.
            int sgx_sim_verify_local_attestation_report(
                [in] const sgx_sim_test_cmw& report,
                [in] const sgx_sim_test_cmw& challenge,
                [out] sgx_sim_local_attestation_verification& verification);
        };
    }
}

#import "json/json.idl"

typedef int error_code;

namespace xxx
{
    [status=demo,description=R"__(Creates an example instance in a subordinate zone
        abd we can do funky shit like this)__"]
    struct something_complicated
    {
        static std::string foo = "hello";

        int int_val;
        std::string string_val;
    };

    [status=demo]
    struct something_more_complicated
    {
        std::vector<something_complicated> vector_val;
        std::map<std::string, something_complicated> map_val;
    };

    [status=demo]
    struct optional_variant_json_holder
    {
        rpc::optional<int32_t> optional_int;
        rpc::variant<int32_t, std::string> variant_value;
        json::v1::object json_value;
        rpc::optional<json::v1::object> optional_json_value;
        rpc::optional<int32_t> rpc_optional_int;
        rpc::optional<json::v1::object> rpc_optional_json_value;
    };

    [status=demo]
    struct rpc_optional_holder
    {
        int32_t required_int;
        std::string required_string;
        rpc::optional<int32_t> optional_int;
        rpc::optional<std::string> optional_string;
        rpc::optional<json::v1::object> optional_json_value;
    };

    enum pointer_serialisation_state
    {
        pointer_serialisation_pending = 0,
        pointer_serialisation_ready = 1,
    };

    [status=demo]
    struct pointer_serialisation_fixture
    {
        pointer_serialisation_state* state = 0;
        error_code* error = 0;
    };

    [status=demo]
    template<typename T>
    struct typed_payload
    {
        std::array<uint8_t, sizeof(T)> payload;
    };

    [status=demo]
    interface i_foo
    {
        static std::string foo = "hello";

        // note local interfaced will not marshal values, so references and pointers are actual caller addresses
        // marshalled values will have temporary placeholder objects in the stubs which will be desroyed after the call
        // rvalue references remain rvalue references in the generated interface so the shared header reflects the IDL
        // proxy-side marshalling may still serialise from a non-consuming view of the argument, while the stub creates
        //   a temporary and passes it to the target using the IDL-declared shape
        error_code do_something_in_val(                                                        int                             val); // marshal by value - implicitly const
        error_code do_something_in_ref(                                [in]            const   int                         &   val); // marshal by value - implicitly const
        error_code do_something_in_move_ref(                           [in]                    int                         &&  val); // marshal by value - implicitly const
        error_code do_something_in_ptr(                                [in]            const   int                         *   val); // marshal by pointer, should note be from another address space
        error_code do_enum_ptr_in(                                     [in]                    pointer_serialisation_state *   val); // marshal enum pointer as an address token
        error_code do_something_out_val(                               [out]                   int                         &   val); // marshal by value
        error_code do_something_out_ptr_ref(                           [out]                   int                         *&  val); // marshal by ref pointer can be null, should note be from another address space
        error_code do_something_out_ptr_ptr(                           [out]                   int                         **  val); // marshal by pointer pointer can be null, should note be from another address space
        error_code do_enum_ptr_out(                                    [out]                   pointer_serialisation_state **  val); // marshal enum pointer pointer as an address token
        error_code do_something_in_out_ref(                            [in, out]               int                         &   val); // marshal by value

        error_code give_something_complicated_val(                     [in]                    something_complicated           val);
        error_code give_something_complicated_ref(                     [in]            const   something_complicated       &   val);
        error_code give_something_complicated_ref_val(                 [in]            const   something_complicated       &   val);
        error_code give_something_complicated_move_ref(                [in]                    something_complicated       &&  val);
        error_code give_something_complicated_ptr(                     [in]            const   something_complicated       *   val);
        error_code receive_something_complicated_ref(                  [out]                   something_complicated       &   val);
        error_code receive_something_complicated_ptr(                  [out]                   something_complicated       *&  val);
        error_code receive_something_complicated_in_out_ref(           [in, out]               something_complicated       &   val);

        error_code give_something_more_complicated_val(                [in]                    something_more_complicated      val);
        error_code give_something_more_complicated_ref(                [in]            const   something_more_complicated  &   val);
        error_code give_something_more_complicated_move_ref(           [in]                    something_more_complicated  &&  val);
        error_code give_something_more_complicated_ref_val(            [in]            const   something_more_complicated  &   val);
        error_code give_something_more_complicated_ptr(                [in]            const   something_more_complicated  *   val);
        error_code receive_something_more_complicated_ref(             [out]                   something_more_complicated  &   val);
        error_code receive_something_more_complicated_ptr(             [out]                   something_more_complicated  *&  val);
        error_code receive_something_more_complicated_in_out_ref(      [in, out]               something_more_complicated  &   val);

        error_code do_multi_val(int val1, int val2);
        error_code do_multi_complicated_val(const something_more_complicated val1, const something_more_complicated val2);
        error_code exchange_json_object([in] const json::v1::object& in_val, [out] json::v1::object& out_val);
        error_code give_optional_variant_json_holder([in] const optional_variant_json_holder& val);
        error_code receive_optional_variant_json_holder([out] optional_variant_json_holder& val);
        error_code exchange_optional_variant_json(
            [in] rpc::optional<int32_t> optional_int,
            [in] rpc::variant<int32_t, std::string> variant_value,
            [in] json::v1::object json_value,
            [in] rpc::optional<json::v1::object> optional_json_value,
            [out] rpc::optional<int32_t>& optional_int_out,
            [out] rpc::variant<int32_t, std::string>& variant_value_out,
            [out] json::v1::object& json_value_out,
            [out] rpc::optional<json::v1::object>& optional_json_value_out);
        error_code exchange_rpc_optional_holder(
            [in] const rpc_optional_holder& in_val,
            [out] rpc_optional_holder& out_val);
        error_code exchange_rpc_optional_values(
            [in] rpc::optional<int32_t> optional_int,
            [in] rpc::optional<json::v1::object> optional_json_value,
            [out] rpc::optional<int32_t>& optional_int_out,
            [out] rpc::optional<json::v1::object>& optional_json_value_out);

        error_code receive_interface([out]rpc::shared_ptr<i_foo>& val);//can be null
        error_code give_interface([in]rpc::shared_ptr<i_baz> val);//can be null
        error_code call_baz_interface([in]const rpc::shared_ptr<i_baz>& val);//can be null
        error_code create_baz_interface([out]rpc::shared_ptr<i_baz>& val);//can be null
        error_code get_null_interface([out]rpc::shared_ptr<i_baz>& val);//can be null

        error_code set_interface([in]const rpc::shared_ptr<i_baz>& val);//can be null
        error_code get_interface([out]rpc::shared_ptr<i_baz>& val);//can be null

        error_code exception_test();

        // Test for [post] attribute - one-way fire-and-forget messaging
        [post] int record_message(int message_id);
        error_code get_recorded_messages([out] std::vector<int>& messages);
        error_code clear_recorded_messages();
    };

    [status=demo]
    interface i_bar
    {
        error_code do_something_else(int val);
    };

    [status=demo]
    interface i_baz
    {
        error_code callback(int val);
        error_code blob_test([in] const std::vector<uint8_t>& in_val, [out] std::vector<uint8_t>& out_val);
    };

    // some template tests with attributes

    // bog standard
    [status=demo]
    template<class T>
    struct test_template
    {
        T type_t;
        static constexpr int x = 3;
    };

    // don't include the template parameters when generating the constexpr value
    [status=demo,buggy_template_param_in_id=false]
    template<class T>
    struct test_template_without_params_in_id
    {
        T type_t;
    };

    // maintain a bug for backward compatibility, use an empty seed for template types seed will be 7410425521722818471ull or 0x66D71EBFF8C6FFA7
    [status=demo,buggy_empty_template_struct_id=true]
    template<class T>
    struct test_template_use_legacy_empty_template_struct_id
    {
        T type_t;
    };

    // use both dodgy flags
    [status=demo,buggy_template_param_in_id=false,buggy_empty_template_struct_id=true]
    template<class T>
    struct test_template_use_old
    {
        T type_t;
    };

    // interfaces use existing logic for now
    [status=demo]
    interface i_interface_with_templates
    {
        error_code one(test_template<int> val);
        error_code two(test_template_without_params_in_id<int> val);
        error_code three(test_template_use_legacy_empty_template_struct_id<int> val);
        error_code four(test_template_use_old<int> val);
    };

    [status=demo]
    struct type_determinant
    {
        static constexpr int x = 3;
    };

    [status=deprecated]
    template<class T>
    struct type_determinant_test
    {
        std::array<uint8_t, T::x> y;
    };

    [status=development]
    template<class T>
    struct test_template
    {
        T type_t;
        static constexpr int x = 3;
    };

}

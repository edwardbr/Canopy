{
  "openapi": "3.0.3",
  "info": {
    "title": "Canopy REST Fixture",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://example.test"
    }
  ],
  "paths": {
    "/todoapi/v1/todos/{todo_id}": {
      "get": {
        "operationId": "getTodo",
        "parameters": [
          {
            "name": "todo_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "include_notes",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Todo item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TodoItem"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "replaceTodo",
        "parameters": [
          {
            "name": "todo_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TodoCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Replaced todo item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TodoItem"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "patchTodo",
        "parameters": [
          {
            "name": "todo_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TodoPatch"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Patched todo item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TodoItem"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteTodo",
        "parameters": [
          {
            "name": "todo_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted todo item"
          }
        }
      },
      "head": {
        "operationId": "headTodo",
        "parameters": [
          {
            "name": "todo_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Todo metadata is available"
          }
        }
      }
    },
    "/todoapi/v1/todos": {
      "post": {
        "operationId": "createTodo",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TodoCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created todo item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TodoItem"
                }
              }
            }
          }
        }
      }
    },
    "/todoapi/v1/todos/options": {
      "options": {
        "operationId": "optionsTodos",
        "responses": {
          "200": {
            "description": "Supported todo methods",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TodoOperationStatus"
                }
              }
            }
          }
        }
      }
    },
    "/todoapi/v1/todos/{todo_id}/audit": {
      "get": {
        "operationId": "getTodoAudit",
        "parameters": [
          {
            "name": "todo_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Todo audit",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TodoAudit"
                }
              }
            }
          }
        }
      }
    },
    "/todoapi/v1/todos/{todo_id}/state": {
      "get": {
        "operationId": "getTodoState",
        "parameters": [
          {
            "name": "todo_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Todo state with ambiguous oneOf fallback",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/TodoItem"
                    },
                    {
                      "$ref": "#/components/schemas/TodoCreate"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TodoAuditBase": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string"
          }
        }
      },
      "TodoAudit": {
        "allOf": [
          {
            "$ref": "#/components/schemas/TodoAuditBase"
          },
          {
            "type": "object",
            "required": [
              "source"
            ],
            "properties": {
              "source": {
                "type": "string"
              },
              "changes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        ]
      },
      "TodoCreate": {
        "type": "object",
        "required": [
          "title",
          "completed"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "completed": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "TodoOperationStatus": {
        "type": "object",
        "required": [
          "id",
          "action"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "action": {
            "type": "string"
          }
        }
      },
      "TodoPatch": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "completed": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "TodoItem": {
        "type": "object",
        "required": [
          "id",
          "title",
          "completed"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "completed": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}

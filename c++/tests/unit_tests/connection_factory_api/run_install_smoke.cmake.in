set(prefix "@CMAKE_CURRENT_BINARY_DIR@/install_smoke")
set(install_script "@CMAKE_BINARY_DIR@/c++/connection_factory/cmake_install.cmake")
set(include_dir "@CMAKE_INSTALL_INCLUDEDIR@")
set(lib_dir "@CMAKE_INSTALL_LIBDIR@")
set(static_library_name "@CMAKE_STATIC_LIBRARY_PREFIX@connection_factory@CMAKE_STATIC_LIBRARY_SUFFIX@")

file(REMOVE_RECURSE "${prefix}")

execute_process(
  COMMAND "@CMAKE_COMMAND@" "-DCMAKE_INSTALL_PREFIX=${prefix}" -P "${install_script}"
  RESULT_VARIABLE install_result
  OUTPUT_VARIABLE install_output
  ERROR_VARIABLE install_error)

if(install_result)
  message(FATAL_ERROR "Connection factory install script failed:\n${install_output}\n${install_error}")
endif()

if(NOT EXISTS "${prefix}/${include_dir}/connection_factory/connection_factory.h")
  message(FATAL_ERROR "Missing installed connection_factory/connection_factory.h")
endif()

if(NOT EXISTS "${prefix}/${include_dir}/connection_factory/context.h")
  message(FATAL_ERROR "Missing installed connection_factory/context.h")
endif()

if(NOT EXISTS "${prefix}/${lib_dir}/${static_library_name}")
  message(FATAL_ERROR "Missing installed ${static_library_name}")
endif()

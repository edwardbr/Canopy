#import "rpc/rpc_types.idl"

namespace rpc
{
    namespace ipc_spsc
    {
        // Host-side settings for an SPSC-backed IPC transport. This transport
        // owns a shared-memory SPSC queue pair and presents it as a Canopy
        // stream transport.
        //
        // The transport can either launch a sidecar process or connect to a
        // peer-to-peer shared-memory file that was created independently by an
        // acceptor process. The peer-to-peer file name is part of the pairing
        // configuration so many independent IPC links can coexist.
        //
        // In sidecar dynamic-library mode it launches the generic
        // canopy_ipc_spsc_sidecar_process executable, which maps the queue pair
        // and loads the configured DLL. In sidecar direct-executable mode the
        // configured executable is application-owned and must use the ipc_spsc
        // process bootstrap arguments to map the queue pair and start its own
        // concrete service interfaces.
        //
        // Connecting to a long-running pre-existing process is a future mode:
        // that will need a named endpoint or rendezvous mechanism in addition
        // to these sidecar settings.
        struct transport_settings
        {
            [description="Name of the parent-side IPC SPSC transport. If service_proxy_name is omitted, this value is also used as the service proxy name."]
            rpc::optional<std::string> name;

            [description="Name passed to service->connect_to_zone for the remote service proxy. When omitted, the factory copies name; when both are omitted, it uses the factory default."]
            rpc::optional<std::string> service_proxy_name;

            [description="Encoding used for generated RPC payloads after the SPSC transport link is live."]
            rpc::optional<rpc::encoding> encoding;

            [description="Launch a child process whose lifetime is owned by this transport. When false, peer_to_peer_shared_memory_file identifies an independently created acceptor pairing."]
            bool use_sidecar = false;

            // File-backed rendezvous for the peer-to-peer mode. This is not
            // used by sidecar mode: sidecar mode creates a private temporary
            // mapped file and passes it to the child process on the command
            // line. For anonymous shared memory or application-owned queue
            // objects there may be no path to configure; inject those queues
            // through connection_factory::context::set_spsc_queues instead.
            [description="Shared-memory file used when use_sidecar is false. The acceptor process normally creates and unlinks this file; the connector process opens it. Relative paths in application topology config are resolved against the topology file directory. Use a unique path per pairing."]
            std::string peer_to_peer_shared_memory_file = "";

            [description="Create peer_to_peer_shared_memory_file before connecting. This is intended for specialised bootstrap tools; ordinary connector processes should leave it false so the acceptor owns the rendezvous file."]
            bool create_peer_to_peer_shared_memory_file = false;

            [description="Unlink peer_to_peer_shared_memory_file when this connector closes. This is normally false because the acceptor owns the file lifetime."]
            bool unlink_peer_to_peer_shared_memory_file_on_close = false;

            [description="Executable path to launch for sidecar mode. In dynamic-library mode this may be omitted when the built-in canopy_ipc_spsc_sidecar_process target is available. In direct-executable mode this must name the application-owned child executable."]
            std::string sidecar_executable_path = "";

            [description="Dynamic library path loaded by the generic sidecar process. Leave empty only when sidecar_executable_path names an application-owned direct executable that implements the RPC endpoint itself."]
            std::string dynamic_library_path = "";

            [description="Offset added to rpc::DEFAULT_PREFIX.get_subnet() to form the child zone subnet. Keep this non-zero so the child zone is distinct from the host service zone."]
            uint64_t child_subnet_offset = 1;

            [description="Scheduler thread count used by the child-host runtime or passed to an application-owned direct executable."]
            uint32_t scheduler_thread_count = 1;

            [description="On Linux, ask the kernel to kill the launched child process if the parent process dies before normal transport shutdown."]
            bool kill_child_on_parent_death = true;
        };
    }
}

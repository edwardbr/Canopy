typedef int error_code;

#import "rpc/rpc_types.idl"
#import "rpc/noop.idl"
#import "streaming/stream_transport.idl"

// Control contract for secure coroutine modules whose runtime cannot directly
// own kernel-visible resources. Ordinary same-zone coroutine code should use
// the native io_uring controller instead of this brokered interface.
namespace rpc
{
    [inline] namespace v4
    {
        namespace secure_coroutine_module
        {
            enum startup_state
            {
                pending = 0,
                workers_requested = 1,
                worker_ready = 2,
                runtime_ready = 3,
                failed = 5,
                shutting_down = 6,
                stopped = 7,
            };
            struct init_request
            {
                rpc::zone parent_zone_id;
                rpc::zone runtime_zone_id;
                rpc::remote_object root_remote_object;
                uint32_t worker_thread_count = 0;
                // Parent-side virtual address of the shared queue carrying messages into the runtime.
                // This is an address token, not serialized queue contents; the runtime adapter validates
                // it before converting it back to the concrete SPSC queue type.
                uint64_t parent_to_runtime_queue_ptr = 0;
                // Parent-side virtual address of the shared queue carrying messages out of the runtime.
                // This is an address token, not serialized queue contents; the runtime adapter validates
                // it before converting it back to the concrete SPSC queue type.
                uint64_t runtime_to_parent_queue_ptr = 0;
                // Parent-shared startup state. The runtime validates this pointer before publishing
                // state changes; low-level atomic access is handled by the runtime implementation.
                startup_state* state = 0;
                // Parent-shared startup error word. The runtime writes this before publishing failed state.
                error_code* error = 0;
                uint64_t ticks_per_millisecond = 0;
                uint64_t initial_unix_epoch_milliseconds = 0;
                std::map<std::string, std::string> options;
            };

            struct enter_thread_request
            {
                rpc::zone runtime_zone_id;
                uint64_t worker_index;
            };

            struct io_uring_fd_data
            {
                uint32_t has_ring_fd = 0;
                int32_t ring_fd = 0;
                uint32_t has_enter_ring_fd = 0;
                int32_t enter_ring_fd = 0;
            };

            struct io_uring_setup_data
            {
                uint32_t setup_flags = 0;
                uint32_t features = 0;
                uint32_t sq_thread_idle_ms = 0;
                uint32_t sq_entries = 0;
                uint32_t cq_entries = 0;
            };

            struct io_uring_sq_data
            {
                uint32_t sq_ring_mask = 0;
                uint32_t sq_ring_entries = 0;

                uint32_t sq_off_head = 0;
                uint32_t sq_off_tail = 0;
                uint32_t sq_off_ring_mask = 0;
                uint32_t sq_off_ring_entries = 0;
                uint32_t sq_off_flags = 0;
                uint32_t sq_off_dropped = 0;
                uint32_t sq_off_array = 0;

                uint64_t sq_ring_ptr = 0;
                uint64_t sq_ring_size = 0;
                uint64_t sq_head_ptr = 0;
                uint64_t sq_tail_ptr = 0;
                uint64_t sq_flags_ptr = 0;
                uint64_t sq_dropped_ptr = 0;
                uint64_t sq_array_ptr = 0;
                uint64_t sqes_ptr = 0;
            };

            struct io_uring_cq_data
            {
                uint32_t cq_ring_mask = 0;
                uint32_t cq_ring_entries = 0;

                uint32_t cq_off_head = 0;
                uint32_t cq_off_tail = 0;
                uint32_t cq_off_ring_mask = 0;
                uint32_t cq_off_ring_entries = 0;
                uint32_t cq_off_overflow = 0;
                uint32_t cq_off_cqes = 0;
                uint32_t cq_off_flags = 0;

                uint64_t cq_ring_ptr = 0;
                uint64_t cq_ring_size = 0;
                uint64_t cq_head_ptr = 0;
                uint64_t cq_tail_ptr = 0;
                uint64_t cq_flags_ptr = 0;
                uint64_t cq_overflow_ptr = 0;
                uint64_t cqes_ptr = 0;
            };

            struct io_uring_buffer_data
            {
                uint64_t buffer_region_ptr = 0;
                uint64_t buffer_region_size = 0;
                uint32_t buffer_size = 0;
                uint32_t buffer_count = 0;
                uint32_t buffers_registered = 0;
                uint32_t registered_buffer_count = 0;
            };

            struct io_uring_fixed_file_data
            {
                uint32_t fixed_files_registered = 0;
                uint32_t fixed_file_count = 0;
            };

            struct io_uring_data
            {
                uint32_t descriptor_version = 2;
                io_uring_fd_data file_descriptors;
                io_uring_setup_data setup;
                io_uring_sq_data submission_queue;
                io_uring_cq_data completion_queue;
                io_uring_buffer_data buffers;
                io_uring_fixed_file_data fixed_files;
            };

            enum brokered_io_operation
            {
                tcp_create_ipv4_socket = 1,
                tcp_create_ipv6_socket = 2,
                tcp_set_socket_reuse_addr = 3,
                tcp_bind_ipv4_loopback = 4,
                tcp_bind_ipv4 = 5,
                tcp_bind_ipv6 = 6,
                tcp_listen = 7,
                tcp_accept = 8,
                tcp_connect_ipv4_loopback = 9,
                tcp_set_tcp_no_delay = 10,
                tcp_send = 11,
                tcp_receive = 12,
                tcp_receive_nonblocking = 13,
                tcp_cancel = 14,
                tcp_close = 15,
                file_open = 16,
                file_read_at = 17,
                file_write_at = 18,
            };

            struct brokered_io_request
            {
                brokered_io_operation operation;
                uint32_t descriptor_id = 0;
                uint32_t value = 0;
                uint32_t flags = 0;
                uint64_t offset = 0;
                std::vector<uint8_t> address;
                std::vector<uint8_t> payload;
            };

            struct brokered_io_result
            {
                int error_code = 0;
                int32_t descriptor_id = 0;
                uint32_t bytes_transferred = 0;
                int32_t native_result = 0;
                uint32_t cqe_flags = 0;
                std::vector<uint8_t> payload;
            };

            interface i_io_uring_control
            {
                int transfer_encapsulated_interface([out] rpc::shared_ptr<rpc::i_noop>& iface);
                int wake_iouring();
                int get_iouring_data([out] io_uring_data& ring_data);
                int brokered_io_operation(brokered_io_request request, [out] brokered_io_result& io_result);
            };
        }
    }
}

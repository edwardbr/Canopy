#import "rpc/rpc_types.idl"

namespace rpc
{
    namespace shared_scheduler_dll
    {
        // Settings for the coroutine native dynamic-library transport where
        // the loaded shared library runs on the host service scheduler.
        //
        // This is a native RPC transport, not an SPSC/IPC transport: calls
        // cross the host/library boundary through coroutine ABI callbacks in
        // the same process. The dynamic library does not own a separate
        // scheduler in this transport variant.
        struct transport_settings
        {
            [description="Name of the host-side dynamic-library transport. If service_proxy_name is omitted, this value is also used as the service proxy name."]
            rpc::optional<std::string> name;

            [description="Name passed to service->connect_to_zone for the loaded-library service proxy. When omitted, the factory copies name; when both are omitted, it uses the factory default."]
            rpc::optional<std::string> service_proxy_name;

            [description="Encoding used for generated RPC payloads after the dynamic-library transport link is live. Omit or use not_set to keep the service default."]
            rpc::optional<rpc::encoding> encoding;

            [description="Path to the shared library loaded into the host process. The library must export the host-scheduled coroutine dynamic-library ABI entry point."]
            std::string dynamic_library_path;
        };
    }
}

#import "rpc/rpc_types.idl"

namespace websocket_demo
{
    namespace v1
    {
        struct connect_request
        {
            // Legacy peer-to-peer handshake field. Web clients should prefer inbound_callback_object_id.
            rpc::remote_object inbound_remote_object;
            // The object id that the browser wants the server to call back on once it assigns a client zone.
            rpc::object inbound_callback_object_id;
        };

        struct connect_response
        {
            // Legacy field kept for older clients. Mirrors client_zone_id.
            rpc::zone caller_zone_id;
            // Legacy field kept for older clients. Mirrors server_remote_object.
            rpc::remote_object outbound_remote_object;
            // The client zone assigned by the server for subsequent websocket RPC calls.
            rpc::zone client_zone_id;
            // The server's zone and callable object combined for subsequent websocket RPC calls.
            rpc::remote_object server_remote_object;
        };

        struct envelope
        {
            uint64_t message_id;
            uint64_t message_type;
            std::vector<char> data;
        };

        struct request
        {
            rpc::encoding encoding;
            uint64_t tag;
            rpc::zone caller_zone_id;
            rpc::remote_object destination_zone_id;
            rpc::interface_ordinal interface_id;
            rpc::method method_id;
            std::vector<char> data;
            std::vector<rpc::back_channel_entry> back_channel;
        };

        struct response
        {
            uint64_t error;
            std::vector<char> data;
            std::vector<rpc::back_channel_entry> back_channel;
        };

        interface i_context_event
        {
            [post] int piece(const std::string& piece);
        };

        [status=demo]
        interface i_calculator
        {
            [description="add"] int add(double first_val, double second_val, [out] double& response);
            [description="subtract"] int subtract(double first_val, double second_val, [out] double& response);
            [description="multiply"] int multiply(double first_val, double second_val, [out] double& response);
            [description="divide"] int divide(double first_val, double second_val, [out] double& response);

            int add_prompt(const std::string& prompt);
            // int get_piece([out] std::string& piece, [out] bool& complete);
            int set_callback(const rpc::shared_ptr<i_context_event>& event);
        };
    }
}

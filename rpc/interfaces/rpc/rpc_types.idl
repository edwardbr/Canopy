    public:
#cpp_quote(R^__(
        destination_zone() = default;
        destination_zone(const destination_zone&) = default;
        destination_zone(destination_zone&&) noexcept = default;
        destination_zone(uint64_t initial_id)
            : addr_(zone_address(initial_id).zone_only())
        {
        }
        destination_zone(const zone_address& addr)
            : addr_(addr.zone_only())
        {
        }
        destination_zone& operator=(const destination_zone&) = default;
        destination_zone& operator=(destination_zone&&) noexcept = default;
        destination_zone& operator=(uint64_t other)
        {
            addr_ = zone_address(other).zone_only();
            return *this;
        }

        uint64_t get_subnet() const { return addr_.get_subnet(); }
        const zone_address& get_address() const { return addr_; }

        // compare
        friend inline bool operator==(const destination_zone& lhs, const destination_zone& rhs);
        template<typename T, std::enable_if_t<std::is_unsigned<T>::value, int> = 0> bool operator==(T val) const
        {
            return addr_.get_subnet() == static_cast<uint64_t>(val);
        }
        friend inline bool operator!=(const destination_zone& lhs, const destination_zone& rhs);
        template<typename T, std::enable_if_t<std::is_unsigned<T>::value, int> = 0> bool operator!=(T val) const
        {
            return addr_.get_subnet() != static_cast<uint64_t>(val);
        }

        bool operator<(uint64_t val) const { return addr_.get_subnet() < val; }
        bool operator<(const destination_zone& val) const { return addr_ < val.addr_; }

        bool is_set() const noexcept { return addr_.is_set(); }

        // create a remote_object from this zone and the given object_id
        inline remote_object with_object(object obj) const;

        inline zone as_zone() const;
        inline caller_zone as_caller() const;
            )__^)
    };


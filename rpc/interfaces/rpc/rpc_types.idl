// note R^ notation is a way to trick they syntax highlighter to not realise it is a multiline comment
#cpp_quote(R^__(
    // the route to all fingerprinting if your type has been through the idl generator a specialised template version of
    // this static functor class will be made allowing you to get the unique id of this type used for serialisation identification
    template<typename T> class id
    {
        // not implemented here! only in concrete derivations
        // static constexpr uint64_t get(rpc_version)
    };
    )__^)

    enum encoding : uint64_t
    {
        yas_binary = 1,
        yas_compressed_binary = 2,
        //yas_text = 4,     //not really needed
        yas_json = 8,       //we may have different json parsers that have a better implementation e.g. glaze
        protocol_buffers = 16,
        // flat_buffers = 32,
        // mpi = 64
    };

    enum add_ref_options : uint8_t
    {
        normal = 0,
        // when unidirectionally addreffing the destination
        build_destination_route = 1,
        // when unidirectionally addreffing the caller which prepares refcounts etc in the reverse direction
        build_caller_route = 2,
        // when the add_ref is from optimistic_ptr reference (assumed shared if not set)
        optimistic = 4
    };

#cpp_quote(R^__(
    inline add_ref_options operator|(add_ref_options lhs, add_ref_options rhs)
    {
        return static_cast<add_ref_options>(static_cast<std::underlying_type<add_ref_options>::type>(lhs)
                                            | static_cast<std::underlying_type<add_ref_options>::type>(rhs));
    }
    inline add_ref_options operator&(add_ref_options lhs, add_ref_options rhs)
    {
        return static_cast<add_ref_options>(static_cast<std::underlying_type<add_ref_options>::type>(lhs)
                                            & static_cast<std::underlying_type<add_ref_options>::type>(rhs));
    }
    inline add_ref_options operator^(add_ref_options lhs, add_ref_options rhs)
    {
        return static_cast<add_ref_options>(static_cast<std::underlying_type<add_ref_options>::type>(lhs)
                                            ^ static_cast<std::underlying_type<add_ref_options>::type>(rhs));
    }

    inline add_ref_options operator~(add_ref_options lhs)
    {
        return static_cast<add_ref_options>(~static_cast<std::underlying_type<add_ref_options>::type>(lhs));
    }

    inline bool operator!(add_ref_options e)
    {
        return e == static_cast<add_ref_options>(0);
    }
    )__^)

    enum release_options : uint8_t
    {
        normal = 0,
        // when the release is from optimistic_ptr reference (assumed shared if not set)
        optimistic = 1
    };

#cpp_quote(R^__(
    inline release_options operator|(release_options lhs, release_options rhs)
    {
        return static_cast<release_options>(static_cast<std::underlying_type<release_options>::type>(lhs)
                                            | static_cast<std::underlying_type<release_options>::type>(rhs));
    }
    inline release_options operator&(release_options lhs, release_options rhs)
    {
        return static_cast<release_options>(static_cast<std::underlying_type<release_options>::type>(lhs)
                                            & static_cast<std::underlying_type<release_options>::type>(rhs));
    }
    inline release_options operator^(release_options lhs, release_options rhs)
    {
        return static_cast<release_options>(static_cast<std::underlying_type<release_options>::type>(lhs)
                                            ^ static_cast<std::underlying_type<release_options>::type>(rhs));
    }

    inline release_options operator~(release_options lhs)
    {
        return static_cast<release_options>(~static_cast<std::underlying_type<release_options>::type>(lhs));
    }

    inline bool operator!(release_options e)
    {
        return e == static_cast<release_options>(0);
    }
    )__^)

    // Back-channel entry for marshalling reference-counted objects across zones
    [no_fingerprint]
    struct back_channel_entry
    {
        uint64_t type_id;
        std::vector<uint8_t> payload;
    };

    // Versioned bit-packed zone address blob.
    //
    // Storage:
    //   - zone_address owns a single variable-length byte blob.
    //   - The first 8 bits are the format version. New addresses default to version 3.
    //   - Network-address payload bytes (IPv4/IPv6) are stored big-endian so they match
    //     conventional internet byte order.
    //   - Other scalar/header fields are packed little-endian to keep the bit helpers cheap.
    //
    // Shared prefix for version 3:
    //   - version               : 8 bits
    //   - address_type          : 3 bits
    //       0 = local
    //       1 = ipv4
    //       2 = ipv6
    //       3 = ipv6_tun
    //       4..7 reserved for future schemes
    //   - has_port              : 1 bit
    //   - subnet_size_bits      : 8 bits
    //   - object_id_size_bits   : 8 bits
    //   - validation_size_bits  : 16 bits
    //   - port                  : 16 bits, present only when has_port == 1 and address_type != local
    //
    // Layout by address_type:
    //
    // local:
    //   - shared prefix
    //   - has_port must be 0
    //   - no routing prefix bytes
    //   - subnet                : subnet_size_bits
    //   - object_id             : object_id_size_bits
    //   - no validation payload bits
    //
    // ipv4:
    //   - shared prefix
    //   - optional port
    //   - routing_prefix_ipv4   : 32 bits, big-endian
    //   - subnet                : subnet_size_bits
    //   - object_id             : object_id_size_bits
    //   - validation            : validation_size_bits
    //   - subnet/object/validation payloads are external to the 32-bit internet address
    //
    // ipv6:
    //   - shared prefix
    //   - optional port
    //   - routing_prefix_ipv6   : 128 bits, big-endian
    //   - subnet                : subnet_size_bits
    //   - object_id             : object_id_size_bits
    //   - validation            : validation_size_bits
    //   - subnet/object/validation payloads are external to the 128-bit internet address
    //
    // ipv6_tun:
    //   - shared prefix
    //   - optional port
    //   - tunneled_ipv6_bits    : 128 bits, big-endian
    //   - validation            : validation_size_bits
    //   - subnet_size_bits and object_id_size_bits describe contiguous regions inside the
    //     128-bit tunneled IPv6 field
    //   - object_id occupies the least-significant object_id_size_bits
    //   - subnet occupies the subnet_size_bits immediately above the object field
    //   - the remaining most-significant bits are the routing prefix
    //
    // Existing helper methods such as get_routing_prefix(), get_subnet(), set_subnet(),
    // get_object_id(), set_object_id(), zone_only() and with_object() are preserved as
    // compatibility shims over this blob representation.

    struct zone_address
    {
    private:
        std::vector<uint8_t> blob;
#cpp_quote(R^__(

    public:
        static constexpr uint8_t version_3 = 3u;
        static constexpr uint8_t default_local_subnet_size_bits = 64u;
        static constexpr uint8_t capability_blob_bytes = 6u;
        zone_address() = default;
        zone_address(const zone_address&) = default;
        zone_address(zone_address&&) noexcept = default;
        zone_address& operator=(const zone_address&) = default;
        zone_address& operator=(zone_address&&) noexcept = default;

        // comparison
        friend inline bool operator==(const zone_address& lhs, const zone_address& rhs);
        friend inline bool operator!=(const zone_address& lhs, const zone_address& rhs);

        enum class address_type : uint8_t
        {
            local = 0,
            ipv4 = 1,
            ipv6 = 2,
            ipv6_tun = 3
        };

        struct construction_args
        {
            uint8_t version = version_3;
            address_type type = address_type::local;
            uint16_t port = 0;
            std::vector<uint8_t> routing_prefix;
            uint8_t subnet_size_bits = default_local_subnet_size_bits;
            uint64_t subnet = 0;
            uint8_t object_id_size_bits = 64u;
            uint64_t object_id = 0;
            std::vector<uint8_t> validation_bits;

            construction_args() = default;
            construction_args(uint8_t version, address_type type, uint16_t port, const std::vector<uint8_t>& routing_prefix, uint8_t subnet_size_bits,
                uint64_t subnet, uint8_t object_id_size_bits, uint64_t object_id, const std::vector<uint8_t>& validation_bits = {})
                : version(version)
                , type(type)
                , port(port)
                , routing_prefix(routing_prefix)
                , subnet_size_bits(subnet_size_bits)
                , subnet(subnet)
                , object_id_size_bits(object_id_size_bits)
                , object_id(object_id)
                , validation_bits(validation_bits)
            {
            }
        };

    private:
        static constexpr uint16_t internet_address_bytes = 16u; // IPv6 and ipv6_tun always carry 128 network bits.
        static constexpr uint8_t version_bits = 8u; // The leading version field.
        static constexpr uint8_t address_type_bits = 3u; // The address_type field inside the capability bits.
        static constexpr uint8_t has_port_bits = 1u; // The single has_port flag bit.
        static constexpr uint8_t reserved_capability_bits = 4u; // Unused capability-bit space reserved for future formats.
        static constexpr uint8_t size_field_bits = 8u; // Width of subnet_size_bits and object_id_size_bits fields.
        static constexpr uint8_t validation_size_field_bits = 16u; // Width of validation_size_bits in the capability bits.
        static constexpr uint8_t port_bits = 16u; // Width of the optional port field after the capability bits.
        static constexpr uint16_t version_offset_bits = 0u; // Version starts at the beginning of the blob.
        static constexpr uint16_t address_type_offset_bits = version_offset_bits + version_bits; // address_type follows the version byte.
        static constexpr uint16_t has_port_offset_bits = address_type_offset_bits + address_type_bits; // has_port follows address_type inside the second byte.
        static constexpr uint16_t subnet_size_offset_bits = 16u; // subnet_size_bits starts at byte 2 of the capability bits.
        static constexpr uint16_t object_id_size_offset_bits = 24u; // object_id_size_bits starts at byte 3 of the capability bits.
        static constexpr uint16_t validation_size_offset_bits = 32u; // validation_size_bits starts at byte 4 of the capability bits.
        static constexpr uint16_t capability_blob_bits = capability_blob_bytes * 8u; // Total width of version + capability bits.
        static constexpr uint16_t header_bits = capability_blob_bits; // The fixed prefix before optional port and address payloads.
        static constexpr uint8_t address_type_mask = 0x7u; // Mask for the low 3 bits of the capability header byte.
        static constexpr uint8_t has_port_mask = 0x8u; // Mask for the has_port bit within the capability header byte.

        static uint64_t get_bits_le(const std::vector<uint8_t>& data, uint16_t offset, uint16_t width);
        static bool set_bits_le(std::vector<uint8_t>& data, uint16_t offset, uint16_t width, uint64_t value);
        static uint64_t get_bits_be(const std::vector<uint8_t>& data, uint16_t offset, uint16_t width);
        static bool set_bits_be(std::vector<uint8_t>& data, uint16_t offset, uint16_t width, uint64_t value);
        static uint16_t address_bits_for_type(address_type type);
        static void validate_prefix_bits(const std::vector<uint8_t>& data, uint16_t width, const char* field_name);
        static std::vector<uint8_t> build_fixed_width_prefix(const std::vector<uint8_t>& data, uint16_t width);
        static std::vector<uint8_t> build_tunnel_host(
            const std::vector<uint8_t>& routing_prefix, uint16_t routing_bits, uint8_t subnet_size_bits, uint64_t subnet, uint8_t object_id_size_bits,
            uint64_t object_id);
        static uint8_t capability_version(const std::array<uint8_t, capability_blob_bytes>& capability_bits);
        static uint8_t capability_header_byte(const std::array<uint8_t, capability_blob_bytes>& capability_bits);
        static address_type capability_address_type(const std::array<uint8_t, capability_blob_bytes>& capability_bits);
        static bool capability_has_port(const std::array<uint8_t, capability_blob_bytes>& capability_bits);
        static uint8_t capability_subnet_size_bits(const std::array<uint8_t, capability_blob_bytes>& capability_bits);
        static uint8_t capability_object_id_size_bits(const std::array<uint8_t, capability_blob_bytes>& capability_bits);
        static uint16_t capability_validation_size_bits(const std::array<uint8_t, capability_blob_bytes>& capability_bits);
        static std::array<uint8_t, capability_blob_bytes> make_capability_bits(
            uint8_t version, address_type type, bool has_port, uint8_t subnet_size_bits, uint8_t object_id_size_bits, uint16_t validation_size_bits);
        static void validate_constructor_args(const std::array<uint8_t, capability_blob_bytes>& capability_bits, uint16_t port,
            const std::vector<uint8_t>& routing_prefix, uint64_t subnet, uint64_t object_id, const std::vector<uint8_t>& validation_bits);
        void initialise_blob(const std::array<uint8_t, capability_blob_bytes>& capability_bits, uint16_t port, const std::vector<uint8_t>& routing_prefix,
            uint64_t subnet, uint64_t object_id, const std::vector<uint8_t>& validation_bits);
        [[nodiscard]] uint16_t address_offset_bits() const;
        [[nodiscard]] uint16_t subnet_offset_bits() const;
        [[nodiscard]] uint16_t object_offset_bits() const;
        [[nodiscard]] uint16_t validation_offset_bits() const;
        [[nodiscard]] std::vector<uint8_t> read_host_bytes() const;
        void write_host_bytes(const std::vector<uint8_t>& host);
        void clear_validation_bits();

    public:
        explicit zone_address(const construction_args& args);
        zone_address(const std::array<uint8_t, capability_blob_bytes>& capability_bits, uint16_t port, const std::vector<uint8_t>& routing_prefix, uint64_t subnet,
            uint64_t object_id, const std::vector<uint8_t>& validation_bits = {});

        [[nodiscard]] uint8_t get_version() const;
        [[nodiscard]] address_type get_address_type() const;
        [[nodiscard]] std::array<uint8_t, capability_blob_bytes> get_capability_bits() const;
        [[nodiscard]] bool has_port() const;
        [[nodiscard]] uint16_t get_port() const;
        [[nodiscard]] uint8_t get_subnet_size_bits() const;
        [[nodiscard]] uint8_t get_object_id_size_bits() const;
        [[nodiscard]] uint16_t get_validation_size_bits() const;
        [[nodiscard]] std::vector<uint8_t> get_routing_prefix() const;
        [[nodiscard]] const std::vector<uint8_t>& get_blob() const { return blob; }
        [[nodiscard]] static constexpr uint8_t get_default_local_object_id_size_bits() { return 64u; }

        [[nodiscard]] uint64_t get_subnet() const;
        [[nodiscard]] uint64_t get_object_id() const;
        bool set_subnet(uint64_t val);
        bool set_object_id(uint64_t val);
        [[nodiscard]] zone_address zone_only() const;
        [[nodiscard]] zone_address with_object(uint64_t obj) const;
        [[nodiscard]] bool same_zone(const zone_address& other) const;
        [[nodiscard]] bool is_set() const noexcept;
        bool operator<(const zone_address& other) const;
    )__^)
    };

#cpp_quote(R^__(
    struct zone;
    struct remote_object;
    struct object;
    )__^)

    struct zone
    {
    private:
        zone_address addr_;

    public:
#cpp_quote(R^__(
        zone() = default;
        zone(const zone&) = default;
        zone(zone&&) noexcept = default;
        zone(const zone_address& addr)
            : addr_(addr.zone_only())
        {
        }
        zone& operator=(const zone&) = default;
        zone& operator=(zone&&) noexcept = default;

        [[nodiscard]] uint64_t get_subnet() const { return addr_.get_subnet(); }
        [[nodiscard]] const zone_address& get_address() const { return addr_; }

        // compare
        friend inline bool operator==(const zone& lhs, const zone& rhs);
        template<typename T, std::enable_if_t<std::is_unsigned<T>::value, int> = 0> bool operator==(T val) const
        {
            return addr_.get_subnet() == static_cast<uint64_t>(val);
        }
        friend inline bool operator!=(const zone& lhs, const zone& rhs);
        template<typename T, std::enable_if_t<std::is_unsigned<T>::value, int> = 0> bool operator!=(T val) const
        {
            return addr_.get_subnet() != static_cast<uint64_t>(val);
        }

        // less
        bool operator<(const zone& val) const { return addr_ < val.addr_; }

        [[nodiscard]] bool is_set() const noexcept { return addr_.is_set(); }

        // create a remote_object from this zone and the given object_id
        [[nodiscard]] inline remote_object with_object(object obj) const;
            )__^)
    };

    typedef zone destination_zone;
    typedef zone caller_zone;
    typedef zone requesting_zone;

    // an id for objects unique to each zone
    struct object
    {
    private:
        uint64_t id = 0;

    public:
#cpp_quote(R^__(
        object() = default;
        object(const object&) = default;
        object(object&&) noexcept = default;
        object(uint64_t initial_id)
            : id(initial_id)
        {
        }
        object& operator=(const object&) = default;
        object& operator=(object&&) noexcept = default;
        object& operator=(uint64_t other)
        {
            id = other;
            return *this;
        }

        [[nodiscard]] uint64_t get_val() const { return id; }

        // compare
        friend inline bool operator==(const object& lhs, const object& rhs);
        template<typename T, std::enable_if_t<std::is_unsigned<T>::value, int> = 0>
        constexpr bool operator==(T val) const
        {
            return id == static_cast<uint64_t>(val);
        }
        friend inline bool operator!=(const object& lhs, const object& rhs);
        template<typename T, std::enable_if_t<std::is_unsigned<T>::value, int> = 0>
        constexpr bool operator!=(T val) const
        {
            return id != static_cast<uint64_t>(val);
        }

        // less
        constexpr bool operator<(uint64_t val) const { return id < val; }
        constexpr bool operator<(object val) const { return id < val.id; }

        [[nodiscard]] constexpr bool is_set() const noexcept { return id != 0; }
            )__^)
    };

    // a destination that carries both zone routing and object identity
    struct remote_object
    {
    private:
        zone_address addr_;

    public:
#cpp_quote(R^__(
        remote_object() = default;
        remote_object(const remote_object&) = default;
        remote_object(remote_object&&) noexcept = default;
        remote_object(const zone_address& addr)
            : addr_(addr)
        {
        }
        remote_object(const destination_zone& d);
        remote_object& operator=(const remote_object&) = default;
        remote_object& operator=(remote_object&&) noexcept = default;

        [[nodiscard]] uint64_t get_subnet() const { return addr_.get_subnet(); }
        [[nodiscard]] const zone_address& get_address() const { return addr_; }

        // compare
        friend inline bool operator==(const remote_object& lhs, const remote_object& rhs);
        template<typename T, std::enable_if_t<std::is_unsigned<T>::value, int> = 0> bool operator==(T val) const
        {
            return addr_.get_subnet() == static_cast<uint64_t>(val);
        }
        friend inline bool operator!=(const remote_object& lhs, const remote_object& rhs);
        template<typename T, std::enable_if_t<std::is_unsigned<T>::value, int> = 0> bool operator!=(T val) const
        {
            return addr_.get_subnet() != static_cast<uint64_t>(val);
        }

        bool operator<(const remote_object& val) const { return addr_ < val.addr_; }

        [[nodiscard]] bool is_set() const noexcept { return addr_.is_set(); }

        // object accessors
        [[nodiscard]] inline object get_object_id() const;
        [[nodiscard]] inline remote_object with_object(object obj) const;

        // zone conversion methods
        [[nodiscard]] inline zone as_zone() const;
            )__^)
    };

    // an id for interfaces
    struct interface_ordinal // cant use the name interface
    {
    private:
        uint64_t id = 0;

    public:
#cpp_quote(R^__(
        interface_ordinal() = default;
        interface_ordinal(const interface_ordinal&) = default;
        interface_ordinal(interface_ordinal&&) noexcept = default;
        interface_ordinal(uint64_t initial_id)
            : id(initial_id)
        {
        }
        interface_ordinal& operator=(const interface_ordinal&) = default;
        interface_ordinal& operator=(interface_ordinal&&) noexcept = default;
        interface_ordinal& operator=(uint64_t other)
        {
            id = other;
            return *this;
        }

        [[nodiscard]] uint64_t get_val() const { return id; }

        // compare
        friend inline bool operator==(const interface_ordinal& lhs, const interface_ordinal& rhs);
        template<typename T, std::enable_if_t<std::is_unsigned<T>::value, int> = 0>
        constexpr bool operator==(T val) const
        {
            return id == static_cast<uint64_t>(val);
        }
        friend inline bool operator!=(const interface_ordinal& lhs, const interface_ordinal& rhs);
        template<typename T, std::enable_if_t<std::is_unsigned<T>::value, int> = 0>
        constexpr bool operator!=(T val) const
        {
            return id != static_cast<uint64_t>(val);
        }

        // less
        constexpr bool operator<(uint64_t val) const { return id < val; }
        constexpr bool operator<(interface_ordinal val) const { return id < val.id; }

        [[nodiscard]] constexpr bool is_set() const noexcept { return id != 0; }
            )__^)
    };

    // an id for method ordinals
    struct method
    {
    private:
        uint64_t id = 0;

    public:
#cpp_quote(R^__(
        method() = default;
        method(const method&) = default;
        method(method&&) noexcept = default;
        method(uint64_t initial_id)
            : id(initial_id)

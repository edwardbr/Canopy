// note R^ notation is a way to trick they syntax highlighter to not realise it is a multiline comment
#cpp_quote(R^__(
    // the route to all fingerprinting if your type has been through the idl generator a specialised template version of
    // this static functor class will be made allowing you to get the unique id of this type used for serialisation identification
    template<typename T> class id
    {
        // not implemented here! only in concrete derivations
        // static constexpr uint64_t get(rpc_version)
    };
    )__^)

    enum encoding : uint64_t
    {
        yas_binary = 1,
        yas_compressed_binary = 2,
        //yas_text = 4,     //not really needed
        yas_json = 8,       //we may have different json parsers that have a better implementation e.g. glaze
        protocol_buffers = 16,
        // flat_buffers = 32,
        // mpi = 64
    };

    enum add_ref_options : uint8_t
    {
        normal = 0,
        // when unidirectionally addreffing the destination
        build_destination_route = 1,
        // when unidirectionally addreffing the caller which prepares refcounts etc in the reverse direction
        build_caller_route = 2,
        // when the add_ref is from optimistic_ptr reference (assumed shared if not set)
        optimistic = 4
    };

#cpp_quote(R^__(
    inline add_ref_options operator|(add_ref_options lhs, add_ref_options rhs)
    {
        return static_cast<add_ref_options>(static_cast<std::underlying_type<add_ref_options>::type>(lhs)
                                            | static_cast<std::underlying_type<add_ref_options>::type>(rhs));
    }
    inline add_ref_options operator&(add_ref_options lhs, add_ref_options rhs)
    {
        return static_cast<add_ref_options>(static_cast<std::underlying_type<add_ref_options>::type>(lhs)
                                            & static_cast<std::underlying_type<add_ref_options>::type>(rhs));
    }
    inline add_ref_options operator^(add_ref_options lhs, add_ref_options rhs)
    {
        return static_cast<add_ref_options>(static_cast<std::underlying_type<add_ref_options>::type>(lhs)
                                            ^ static_cast<std::underlying_type<add_ref_options>::type>(rhs));
    }

    inline add_ref_options operator~(add_ref_options lhs)
    {
        return static_cast<add_ref_options>(~static_cast<std::underlying_type<add_ref_options>::type>(lhs));
    }

    inline bool operator!(add_ref_options e)
    {
        return e == static_cast<add_ref_options>(0);
    }
    )__^)

    enum release_options : uint8_t
    {
        normal = 0,
        // when the release is from optimistic_ptr reference (assumed shared if not set)
        optimistic = 1
    };

#cpp_quote(R^__(
    inline release_options operator|(release_options lhs, release_options rhs)
    {
        return static_cast<release_options>(static_cast<std::underlying_type<release_options>::type>(lhs)
                                            | static_cast<std::underlying_type<release_options>::type>(rhs));
    }
    inline release_options operator&(release_options lhs, release_options rhs)
    {
        return static_cast<release_options>(static_cast<std::underlying_type<release_options>::type>(lhs)
                                            & static_cast<std::underlying_type<release_options>::type>(rhs));
    }
    inline release_options operator^(release_options lhs, release_options rhs)
    {
        return static_cast<release_options>(static_cast<std::underlying_type<release_options>::type>(lhs)
                                            ^ static_cast<std::underlying_type<release_options>::type>(rhs));
    }

    inline release_options operator~(release_options lhs)
    {
        return static_cast<release_options>(~static_cast<std::underlying_type<release_options>::type>(lhs));
    }

    inline bool operator!(release_options e)
    {
        return e == static_cast<release_options>(0);
    }
    )__^)

    // Back-channel entry for marshalling reference-counted objects across zones
    [no_fingerprint]
    struct back_channel_entry
    {
        uint64_t type_id;
        std::vector<uint8_t> payload;
    };

    // IPv6-inspired zone address with routing prefix, subnet (zone), and object identity.
    //
    // Two storage layouts are available via the CANOPY_FIXED_ADDRESS_SIZE cmake option:
    //
    // Fixed layout (CANOPY_FIXED_ADDRESS_SIZE defined – default on MSVC):
    //   uint64_t routing_prefix, uint32_t subnet_id, uint32_t object_id
    //   Max constants max_routing_prefix / max_subnet / max_object_id are available.
    //   Constructor: zone_address(uint64_t prefix, uint32_t subnet, uint32_t obj = 0)
    //

// if you only need 32 bits for ipv4 then it makes sense to reduce these values to a more sensible sizes
// if you dont need to make this work on the internet then you can reduce the size of the host address to 0
// the host address could be hashed to a smaller size if you do not need to pass an object reference in machine A
// living in machine B, to machine C
#ifndef CANOPY_HOST_ADDRESS_SIZE
// this is big enough to store a 128 bit ipv6 address
#define CANOPY_HOST_ADDRESS_SIZE 16
#endif

#ifndef CANOPY_LOCAL_ADDRESS_SIZE
// this is big enough to store a 120 bit local address
#define CANOPY_LOCAL_ADDRESS_SIZE 15
#endif

    // Flexible layout (CANOPY_FIXED_ADDRESS_SIZE not defined – default on GCC/Clang):
    //   host_address stores the full reversible host identity.
    //   local_address is a (CANOPY_LOCAL_ADDRESS_SIZE * 8)-bit local payload
    //   split by object_offset:
    //     bits [0 .. object_offset-1]                    subnet ID
    //     bits [object_offset .. object_limit-1]         object ID
    //     bits [hash_offset .. (N * 8) - 1]              optional address hash
    //   Constructor: zone_address(std::array<uint8_t, CANOPY_HOST_ADDRESS_SIZE> host_address,
    //                             uint8_t object_offset, uint32_t obj = 0)
    struct zone_address
    {
#ifdef CANOPY_FIXED_ADDRESS_SIZE
        // max values for each field based on the fixed storage type
        static constexpr uint64_t max_routing_prefix = UINT64_MAX;
        static constexpr uint64_t max_subnet = UINT32_MAX;
        static constexpr uint64_t max_object_id = UINT32_MAX;

    private:
        uint64_t routing_prefix = 0;
        uint32_t subnet_id = 0;
        uint32_t object_id = 0;
#else
        static constexpr uint8_t host_address_size = CANOPY_HOST_ADDRESS_SIZE;
        static constexpr uint8_t local_address_size = CANOPY_LOCAL_ADDRESS_SIZE;

    private:
        std::array<uint8_t, host_address_size> host_address = {};
        std::array<uint8_t, local_address_size> local_address = {};
        uint8_t object_offset_ = 0;
#ifdef CANOPY_HASH_ADDRESS_SIZE
        static constexpr uint8_t hash_offset_ = CANOPY_HASH_ADDRESS_SIZE;
#endif
#endif
#cpp_quote(R^__(

    public:
        zone_address() = default;
        zone_address(const zone_address&) = default;
        zone_address(zone_address&&) noexcept = default;
        zone_address& operator=(const zone_address&) = default;
        zone_address& operator=(zone_address&&) noexcept = default;

        // comparison
        friend inline bool operator==(const zone_address& lhs, const zone_address& rhs);
        friend inline bool operator!=(const zone_address& lhs, const zone_address& rhs);

#ifdef CANOPY_FIXED_ADDRESS_SIZE
        constexpr zone_address(uint64_t prefix, uint32_t subnet, uint32_t obj = 0)
            : routing_prefix(prefix)
            , subnet_id(subnet)
            , object_id(obj)
        {
        }

        // accessors
        [[nodiscard]] uint64_t get_routing_prefix() const { return routing_prefix; }
        [[nodiscard]] std::array<uint8_t, host_address_size> get_host_address() const
        {
            std::array<uint8_t, host_address_size> host = {};
            size_t prefix_bytes = host.size() < 8 ? host.size() : 8u;
            for (size_t i = 0; i < prefix_bytes; ++i)
            {
                host[(prefix_bytes - 1u) - i] = static_cast<uint8_t>(routing_prefix >> (i * 8));
            }
            return host;
        }
        bool set_routing_prefix(uint64_t val)
        {
            if (val > max_routing_prefix)
                return false;
            routing_prefix = val;
            return true;
        }

        [[nodiscard]] uint64_t get_subnet() const { return static_cast<uint64_t>(subnet_id); }
        bool set_subnet(uint64_t val)
        {
            if (val > max_subnet)
                return false;
            subnet_id = static_cast<uint32_t>(val);
            return true;
        }

        [[nodiscard]] uint64_t get_object_id() const { return static_cast<uint64_t>(object_id); }
        bool set_object_id(uint64_t val)
        {
            if (val > max_object_id)
                return false;
            object_id = static_cast<uint32_t>(val);
            return true;
        }

        // zone-only address (strips object_id)
        [[nodiscard]] zone_address zone_only() const { return zone_address(routing_prefix, subnet_id, 0); }

        // return a copy with a different object_id
        [[nodiscard]] zone_address with_object(uint64_t obj) const
        {
            return zone_address(routing_prefix, subnet_id, static_cast<uint32_t>(obj));
        }

        // check if two addresses refer to the same zone (ignoring object_id)
        [[nodiscard]] bool same_zone(const zone_address& other) const
        {
            return routing_prefix == other.routing_prefix && subnet_id == other.subnet_id;
        }

        [[nodiscard]] bool is_set() const noexcept { return routing_prefix != 0 || subnet_id != 0; }

        bool operator<(const zone_address& other) const
        {
            if (routing_prefix != other.routing_prefix)
                return routing_prefix < other.routing_prefix;
            if (subnet_id != other.subnet_id)
                return subnet_id < other.subnet_id;
            return object_id < other.object_id;
        }

#else // flexible layout: configurable host bytes plus a configurable local payload

    private:
        static constexpr uint8_t host_address_bytes = host_address_size;
        static constexpr uint8_t local_address_bytes = local_address_size;
        static constexpr uint16_t local_address_bits = local_address_size * 8u;
#ifdef CANOPY_HASH_ADDRESS_SIZE
        static constexpr uint8_t hash_bits_value_() { return CANOPY_HASH_ADDRESS_SIZE; }
        static constexpr uint8_t hash_offset_value_()
        {
            return static_cast<uint8_t>(local_address_bits - hash_bits_value_());
        }
#endif

        static constexpr uint8_t object_limit_()
        {
#ifdef CANOPY_HASH_ADDRESS_SIZE
            return hash_offset_value_();
#else
            return static_cast<uint8_t>(local_address_bits);
#endif
        }

        static uint64_t get_local_bits(const std::array<uint8_t, local_address_size>& data, uint8_t begin, uint8_t end)
        {
            if (end <= begin)
                return 0;

            auto width = end - begin;
            if (width > 64u)
                width = 64u;

            uint64_t value = 0;
            auto bit_offset = static_cast<uint8_t>(begin % 8u);
            auto start_byte = static_cast<uint8_t>((data.size() - 1u) - (begin / 8u));
            auto bytes_to_read = static_cast<uint8_t>((bit_offset + width + 7u) / 8u);
            for (uint8_t i = 0; i < bytes_to_read; ++i)
            {
                value |= static_cast<uint64_t>(data[start_byte - i]) << (i * 8u);
            }
            value >>= bit_offset;

            if (width == 64u)
                return value;

            return value & ((uint64_t(1) << width) - 1u);
        }

        static bool set_local_bits(std::array<uint8_t, local_address_size>& data, uint8_t begin, uint8_t end, uint64_t value)
        {
            if (end <= begin)
                return value == 0;

            uint8_t width = end - begin;
            if (width < 64u && value >= (uint64_t(1) << width))
                return false;

            auto bit_offset = static_cast<uint8_t>(begin % 8u);
            auto start_byte = static_cast<uint8_t>((data.size() - 1u) - (begin / 8u));
            auto bytes_to_write = static_cast<uint8_t>((bit_offset + width + 7u) / 8u);
            uint64_t current = 0;
            for (uint8_t i = 0; i < bytes_to_write; ++i)
            {
                current |= static_cast<uint64_t>(data[start_byte - i]) << (i * 8u);
            }

            uint64_t mask = width == 64u ? UINT64_MAX : ((uint64_t(1) << width) - 1u);
            current &= ~(mask << bit_offset);
            current |= (value & mask) << bit_offset;

            for (uint8_t i = 0; i < bytes_to_write; ++i)
            {
                data[start_byte - i] = static_cast<uint8_t>((current >> (i * 8u)) & 0xffu);
            }
            return true;
        }

        static uint64_t host_prefix64(const std::array<uint8_t, host_address_size>& host)
        {
            uint64_t prefix = 0;
            size_t prefix_bytes = host.size() < 8 ? host.size() : 8u;
            for (size_t i = 0; i < prefix_bytes; ++i)
            {
                prefix = (prefix << 8) | host[i];
            }
            return prefix;
        }

    public:
        zone_address(uint64_t prefix, uint32_t subnet, uint32_t obj = 0)
            : object_offset_(64)
        {
            size_t prefix_bytes = host_address.size() < 8 ? host_address.size() : 8u;
            for (size_t i = 0; i < prefix_bytes; ++i)
            {
                host_address[(prefix_bytes - 1u) - i] = static_cast<uint8_t>(prefix >> (i * 8));
            }
            [[maybe_unused]] bool subnet_ok = set_subnet(subnet);
            [[maybe_unused]] bool object_ok = set_object_id(obj);
            // RPC_ASSERT(subnet_ok);
            // RPC_ASSERT(object_ok);
        }

        zone_address(std::array<uint8_t, host_address_size> host, uint8_t object_offset, uint32_t obj = 0)
            : host_address(host)
            , object_offset_(object_offset)
        {
            // RPC_ASSERT(object_offset <= local_address_bits);
            [[maybe_unused]] bool ok = set_object_id(obj);
            // RPC_ASSERT(ok);
        }

        template<size_t N>
        zone_address(const std::array<uint8_t, N>& host, uint8_t object_offset, uint32_t obj = 0)
            : object_offset_(object_offset)
        {
            constexpr size_t copy_bytes = N < host_address_size ? N : host_address_size;
            for (size_t i = 0; i < copy_bytes; ++i)
            {
                host_address[i] = host[i];
            }
            // RPC_ASSERT(object_offset <= local_address_bits);
            [[maybe_unused]] bool ok = set_object_id(obj);
            // RPC_ASSERT(ok);
        }

        [[nodiscard]] uint64_t get_routing_prefix() const { return host_prefix64(host_address); }
        [[nodiscard]] const std::array<uint8_t, host_address_size>& get_host_address() const { return host_address; }
        [[nodiscard]] uint8_t get_object_offset() const { return object_offset_; }
        [[nodiscard]] static constexpr uint16_t get_local_address_bits() { return local_address_bits; }
#ifdef CANOPY_HASH_ADDRESS_SIZE
        [[nodiscard]] static constexpr uint8_t get_hash_offset() { return hash_offset_value_(); }
        [[nodiscard]] static constexpr uint8_t get_hash_bits() { return hash_bits_value_(); }
#endif

        [[nodiscard]] uint64_t get_subnet() const { return get_local_bits(local_address, 0, object_offset_); }

        [[nodiscard]] uint64_t get_object_id() const { return get_local_bits(local_address, object_offset_, object_limit_()); }

        bool set_subnet(uint64_t val) { return set_local_bits(local_address, 0, object_offset_, val); }

        bool set_object_id(uint64_t val) { return set_local_bits(local_address, object_offset_, object_limit_(), val); }

#ifdef CANOPY_HASH_ADDRESS_SIZE
        [[nodiscard]] uint64_t get_hash() const { return get_local_bits(local_address, hash_offset_value_(), local_address_bits); }

        bool set_hash(uint64_t val)
        {
            return set_local_bits(local_address, hash_offset_value_(), local_address_bits, val);
        }
#endif

        [[nodiscard]] zone_address zone_only() const
        {
            zone_address copy(*this);
            [[maybe_unused]] bool ok = copy.set_object_id(0);
            // RPC_ASSERT(ok);
            return copy;
        }

        [[nodiscard]] zone_address with_object(uint64_t obj) const
        {
            zone_address copy(*this);
            [[maybe_unused]] bool ok = copy.set_object_id(obj);
            // RPC_ASSERT(ok);
            return copy;
        }

        [[nodiscard]] bool same_zone(const zone_address& other) const
        {
            return host_address == other.host_address && object_offset_ == other.object_offset_
                   && get_subnet() == other.get_subnet();
        }

        [[nodiscard]] bool is_set() const noexcept
        {
            if (object_offset_ != 0)
                return true;
            for (auto byte : host_address)
            {
                if (byte != 0)
                    return true;
            }
            for (auto byte : local_address)
            {
                if (byte != 0)
                    return true;
            }
            return false;
        }

        bool operator<(const zone_address& other) const
        {
            if (host_address != other.host_address)
                return host_address < other.host_address;
            if (object_offset_ != other.object_offset_)
                return object_offset_ < other.object_offset_;
            return local_address < other.local_address;
        }

#endif // CANOPY_FIXED_ADDRESS_SIZE
    )__^)
    };

#cpp_quote(R^__(
    struct zone;
    struct remote_object;
    struct object;
    )__^)

    struct zone
    {
    private:
        zone_address addr_;

    public:
#cpp_quote(R^__(
        zone() = default;
        zone(const zone&) = default;
        zone(zone&&) noexcept = default;
        zone(const zone_address& addr)
            : addr_(addr.zone_only())
        {
        }
        zone& operator=(const zone&) = default;
        zone& operator=(zone&&) noexcept = default;

        [[nodiscard]] uint64_t get_subnet() const { return addr_.get_subnet(); }
        [[nodiscard]] const zone_address& get_address() const { return addr_; }

        // compare
        friend inline bool operator==(const zone& lhs, const zone& rhs);
        template<typename T, std::enable_if_t<std::is_unsigned<T>::value, int> = 0> bool operator==(T val) const
        {
            return addr_.get_subnet() == static_cast<uint64_t>(val);
        }
        friend inline bool operator!=(const zone& lhs, const zone& rhs);
        template<typename T, std::enable_if_t<std::is_unsigned<T>::value, int> = 0> bool operator!=(T val) const
        {
            return addr_.get_subnet() != static_cast<uint64_t>(val);
        }

        // less
        bool operator<(const zone& val) const { return addr_ < val.addr_; }

        [[nodiscard]] bool is_set() const noexcept { return addr_.is_set(); }

        // create a remote_object from this zone and the given object_id
        [[nodiscard]] inline remote_object with_object(object obj) const;
            )__^)
    };

    typedef zone destination_zone;
    typedef zone caller_zone;
    typedef zone requesting_zone;

    // an id for objects unique to each zone
    struct object
    {
    private:
        uint64_t id = 0;

    public:
#cpp_quote(R^__(
        object() = default;
        object(const object&) = default;
        object(object&&) noexcept = default;
        object(uint64_t initial_id)
            : id(initial_id)
        {
        }
        object& operator=(const object&) = default;
        object& operator=(object&&) noexcept = default;
        object& operator=(uint64_t other)
        {
            id = other;
            return *this;
        }

        [[nodiscard]] uint64_t get_val() const { return id; }

        // compare
        friend inline bool operator==(const object& lhs, const object& rhs);
        template<typename T, std::enable_if_t<std::is_unsigned<T>::value, int> = 0>
        constexpr bool operator==(T val) const
        {
            return id == static_cast<uint64_t>(val);
        }
        friend inline bool operator!=(const object& lhs, const object& rhs);
        template<typename T, std::enable_if_t<std::is_unsigned<T>::value, int> = 0>
        constexpr bool operator!=(T val) const
        {
            return id != static_cast<uint64_t>(val);
        }

        // less
        constexpr bool operator<(uint64_t val) const { return id < val; }
        constexpr bool operator<(object val) const { return id < val.id; }

        [[nodiscard]] constexpr bool is_set() const noexcept { return id != 0; }
            )__^)
    };

    // a destination that carries both zone routing and object identity
    struct remote_object
    {
    private:
        zone_address addr_;

    public:
#cpp_quote(R^__(
        remote_object() = default;
        remote_object(const remote_object&) = default;
        remote_object(remote_object&&) noexcept = default;
        remote_object(const zone_address& addr)
            : addr_(addr)
        {
        }
        remote_object(const destination_zone& d);
        remote_object& operator=(const remote_object&) = default;
        remote_object& operator=(remote_object&&) noexcept = default;

        [[nodiscard]] uint64_t get_subnet() const { return addr_.get_subnet(); }
        [[nodiscard]] const zone_address& get_address() const { return addr_; }

        // compare
        friend inline bool operator==(const remote_object& lhs, const remote_object& rhs);
        template<typename T, std::enable_if_t<std::is_unsigned<T>::value, int> = 0> bool operator==(T val) const
        {
            return addr_.get_subnet() == static_cast<uint64_t>(val);
        }
        friend inline bool operator!=(const remote_object& lhs, const remote_object& rhs);
        template<typename T, std::enable_if_t<std::is_unsigned<T>::value, int> = 0> bool operator!=(T val) const
        {
            return addr_.get_subnet() != static_cast<uint64_t>(val);
        }

        bool operator<(const remote_object& val) const { return addr_ < val.addr_; }

        [[nodiscard]] bool is_set() const noexcept { return addr_.is_set(); }

        // object accessors
        [[nodiscard]] inline object get_object() const;
        [[nodiscard]] inline remote_object with_object(object obj) const;

        // zone conversion methods
        [[nodiscard]] inline zone as_zone() const;
            )__^)
    };

    // an id for interfaces
    struct interface_ordinal // cant use the name interface
    {
    private:
        uint64_t id = 0;

    public:
#cpp_quote(R^__(
        interface_ordinal() = default;
        interface_ordinal(const interface_ordinal&) = default;
        interface_ordinal(interface_ordinal&&) noexcept = default;
        interface_ordinal(uint64_t initial_id)
            : id(initial_id)
        {
        }
        interface_ordinal& operator=(const interface_ordinal&) = default;
        interface_ordinal& operator=(interface_ordinal&&) noexcept = default;
        interface_ordinal& operator=(uint64_t other)
        {
            id = other;
            return *this;
        }

        [[nodiscard]] uint64_t get_val() const { return id; }

        // compare
        friend inline bool operator==(const interface_ordinal& lhs, const interface_ordinal& rhs);
        template<typename T, std::enable_if_t<std::is_unsigned<T>::value, int> = 0>
        constexpr bool operator==(T val) const
        {
            return id == static_cast<uint64_t>(val);
        }
        friend inline bool operator!=(const interface_ordinal& lhs, const interface_ordinal& rhs);
        template<typename T, std::enable_if_t<std::is_unsigned<T>::value, int> = 0>
        constexpr bool operator!=(T val) const
        {
            return id != static_cast<uint64_t>(val);
        }

        // less
        constexpr bool operator<(uint64_t val) const { return id < val; }
        constexpr bool operator<(interface_ordinal val) const { return id < val.id; }

        [[nodiscard]] constexpr bool is_set() const noexcept { return id != 0; }
            )__^)
    };

    // an id for method ordinals
    struct method
    {
    private:
        uint64_t id = 0;

    public:
#cpp_quote(R^__(
        method() = default;
        method(const method&) = default;
        method(method&&) noexcept = default;
        method(uint64_t initial_id)
            : id(initial_id)
        {
        }
        method& operator=(const method&) = default;
        method& operator=(method&&) noexcept = default;
        method& operator=(uint64_t other)
        {
            id = other;
            return *this;
        }

        [[nodiscard]] uint64_t get_val() const { return id; }

        // compare
        friend inline bool operator==(const method& lhs, const method& rhs);
        template<typename T, std::enable_if_t<std::is_unsigned<T>::value, int> = 0>
        constexpr bool operator==(T val) const
        {
            return id == static_cast<uint64_t>(val);
        }
        friend inline bool operator!=(const method& lhs, const method& rhs);
        template<typename T, std::enable_if_t<std::is_unsigned<T>::value, int> = 0>
        constexpr bool operator!=(T val) const
        {
            return id != static_cast<uint64_t>(val);
        }

        // less
        constexpr bool operator<(uint64_t val) const { return id < val; }
        constexpr bool operator<(method val) const { return id < val.id; }

        [[nodiscard]] constexpr bool is_set() const noexcept { return id != 0; }
            )__^)
    };

#cpp_quote(R^__(
    // converters

    [[nodiscard]] inline remote_object zone::with_object(object obj) const
    {
        return remote_object(addr_.with_object(obj.get_val()));
    }

    // remote_object implementations
    [[nodiscard]] inline object remote_object::get_object() const
    {
        return object(addr_.get_object_id());
    }

    [[nodiscard]] inline remote_object remote_object::with_object(object obj) const
    {
        return remote_object(addr_.with_object(obj.get_val()));
    }

    [[nodiscard]] inline zone remote_object::as_zone() const
    {
        return zone(addr_);
    }

    inline remote_object::remote_object(const destination_zone& d)
        : addr_(d.get_address())
    {
    }

    // Cross-type comparisons: remote_object vs destination_zone
    // destination_zone is zone-only, so compare zone fields using same_zone()
    inline bool operator==(const remote_object& lhs, const destination_zone& rhs)
    {
        return lhs.get_address().same_zone(rhs.get_address());
    }
    inline bool operator!=(const remote_object& lhs, const destination_zone& rhs)
    {
        return !lhs.get_address().same_zone(rhs.get_address());
    }
    inline bool operator==(const destination_zone& lhs, const remote_object& rhs)
    {
        return lhs.get_address().same_zone(rhs.get_address());
    }
    inline bool operator!=(const destination_zone& lhs, const remote_object& rhs)
    {
        return !lhs.get_address().same_zone(rhs.get_address());
    }

// Default routing prefix for local-node zone addresses (routing_prefix=0, subnet=1).
// Use when the application does not specify a routing prefix explicitly.
//
// Flexible layout: host bytes are zero and local fields use the default
//   subnet/object split within the configurable local payload
//   (120 bits when local_address_size is left at 15).
#ifdef CANOPY_FIXED_ADDRESS_SIZE
    static constexpr zone_address DEFAULT_PREFIX(0, 1);
#else
    inline const zone_address DEFAULT_PREFIX = []()
    {
        zone_address addr({}, 64, 0);
        [[maybe_unused]] bool ok = addr.set_subnet(1);
        // RPC_ASSERT(ok);
        return addr;
    }();
#endif
    )__^)

    struct interface_descriptor
    {
        remote_object destination_zone_id;

    public:
#cpp_quote(R^__(
        interface_descriptor() = default;
        interface_descriptor(const interface_descriptor&) = default;
        interface_descriptor(interface_descriptor&&) noexcept = default;
        interface_descriptor& operator=(const interface_descriptor&) = default;
        interface_descriptor& operator=(interface_descriptor&&) noexcept = default;

        // construct with object embedded in remote_object
        interface_descriptor(object obj, destination_zone dest)
            : destination_zone_id(dest.with_object(obj))
        {
        }

        // construct from remote_object (carries zone + object)
        interface_descriptor(remote_object dest)
            : destination_zone_id(dest)
        {
        }

        // construct from destination_zone (zone-only, no object)
        interface_descriptor(destination_zone dest)
            : destination_zone_id(dest)
        {
        }

        // accessor for the embedded object_id
        [[nodiscard]] object get_object_id() const { return destination_zone_id.get_object(); }
    )__^)
    };

    struct connection_settings
    {
        interface_ordinal inbound_interface_id;
        interface_ordinal outbound_interface_id;
        remote_object remote_object_id;

    public:
#cpp_quote(R^__(
        connection_settings() = default;
        connection_settings(const connection_settings&) = default;
        connection_settings(connection_settings&&) noexcept = default;
        connection_settings& operator=(const connection_settings&) = default;
        connection_settings& operator=(connection_settings&&) noexcept = default;

        // accessor for the embedded object_id in remote_object_id
        [[nodiscard]] object get_object_id() const { return remote_object_id.get_object(); }
    )__^)
    };

    struct function_info
    {
        std::string full_name;
        std::string name;
        method id;
        uint64_t tag;
        bool marshalls_interfaces;
        std::string description;
        std::string in_json_schema;
        std::string out_json_schema;
    };
}

#cpp_quote(R^__(
    // converters
    destination_zone zone::as_destination() const
    {
        return destination_zone(addr_);
    }
    caller_zone zone::as_caller() const
    {
        return caller_zone(addr_);
    }

    requesting_zone zone::as_requesting_zone() const
    {
        return requesting_zone(addr_);
    }

    zone destination_zone::as_zone() const
    {
        return zone(addr_);
    }

    caller_zone destination_zone::as_caller() const
    {
        return caller_zone(addr_);
    }

    destination_zone caller_zone::as_destination() const
    {
        return destination_zone(addr_);
    }

    requesting_zone caller_zone::as_requesting_zone() const
    {
        return requesting_zone(addr_);
    }

    destination_zone requesting_zone::as_destination() const
    {
        return destination_zone(addr_);
    }

    inline remote_object destination_zone::with_object(object obj) const
    {
        return remote_object(addr_.with_object(obj.get_val()));
    }

    // remote_object implementations
    inline object remote_object::get_object() const
    {
        return object(addr_.get_object_id());
    }

    inline remote_object remote_object::with_object(object obj) const
    {
        return remote_object(addr_.with_object(obj.get_val()));
    }

    inline zone remote_object::as_zone() const
    {
        return zone(addr_);
    }

    inline caller_zone remote_object::as_caller() const
    {
        return caller_zone(addr_);
    }

    inline destination_zone remote_object::as_destination_zone() const
    {
        return destination_zone(addr_);
    }

    inline remote_object::operator destination_zone() const
    {
        return destination_zone(addr_);
    }

    inline remote_object::remote_object(const destination_zone& d)
        : addr_(d.get_address())
    {
    }

    // Cross-type comparisons: remote_object vs destination_zone
    // destination_zone is zone-only, so compare zone fields using same_zone()
    inline bool operator==(const remote_object& lhs, const destination_zone& rhs)
    {
        return lhs.get_address().same_zone(rhs.get_address());
    }
    inline bool operator!=(const remote_object& lhs, const destination_zone& rhs)
    {
        return !lhs.get_address().same_zone(rhs.get_address());
    }
    inline bool operator==(const destination_zone& lhs, const remote_object& rhs)
    {
        return lhs.get_address().same_zone(rhs.get_address());
    }
    inline bool operator!=(const destination_zone& lhs, const remote_object& rhs)
    {
        return !lhs.get_address().same_zone(rhs.get_address());
    }
    )__^)

    struct interface_descriptor
    {
        remote_object destination_zone_id;

    public:
#cpp_quote(R^__(
        interface_descriptor() = default;
        interface_descriptor(const interface_descriptor&) = default;
        interface_descriptor(interface_descriptor&&) noexcept = default;
        interface_descriptor& operator=(const interface_descriptor&) = default;
        interface_descriptor& operator=(interface_descriptor&&) noexcept = default;

        // construct with object embedded in remote_object
        interface_descriptor(object obj, destination_zone dest)
            : destination_zone_id(dest.with_object(obj))
        {
        }

        // construct from remote_object (carries zone + object)
        interface_descriptor(remote_object dest)
            : destination_zone_id(dest)
        {
        }

        // construct from destination_zone (zone-only, no object)
        interface_descriptor(destination_zone dest)
            : destination_zone_id(dest)
        {
        }

        // accessor for the embedded object_id
        object get_object_id() const { return destination_zone_id.get_object(); }
    )__^)
    };

    struct connection_settings
    {
        interface_ordinal inbound_interface_id;
        interface_ordinal outbound_interface_id;
        remote_object input_zone_id;

    public:
#cpp_quote(R^__(
        connection_settings() = default;
        connection_settings(const connection_settings&) = default;
        connection_settings(connection_settings&&) noexcept = default;
        connection_settings& operator=(const connection_settings&) = default;
        connection_settings& operator=(connection_settings&&) noexcept = default;

        // accessor for the embedded object_id in input_zone_id
        object get_object_id() const { return input_zone_id.get_object(); }
    )__^)
    };

    struct function_info
    {
        std::string full_name;
        std::string name;
        method id;
        uint64_t tag;
        bool marshalls_interfaces;
        std::string description;
        std::string in_json_schema;
        std::string out_json_schema;
    };
}
